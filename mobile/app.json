{
  "expo": {
    "name": "AutoPac",
    "slug": "autopac",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "autopac",
    "splash": {
      "backgroundColor": "#1a1a2e"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.autopac.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1a1a2e"
      },
      "package": "com.autopac.app"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#e94560"
        }
      ],
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "projectId": "13da6bb8-4b14-438f-b518-9a41b4619b09"
      }
    },
    "owner": "takrimk"
  }
}
