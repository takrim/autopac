# Backend (set these in Firebase Functions config or .env)
WEBHOOK_SECRET=your-strong-random-secret-here
ACTIVE_BROKER=mock
PAPER_TRADING=true

# Alpaca (only needed if ACTIVE_BROKER=alpaca)
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

